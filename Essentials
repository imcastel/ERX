-- ====================== Car QoL Features ======================
local function issitting(humanoid)
    return humanoid and humanoid.SeatPart ~= nil
end

local function enterCar()
    local character = LocalPlayer.Character
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    if not humanoid then Notify("Enter Car", "No character found!", 3) return end
    if issitting(humanoid) then Notify("Enter Car", "You're already in a vehicle!", 3) return end
    local vehicle = Functions:GetCurrentLocalPlayerCar() or GetVehicle()
    if not vehicle then Notify("Enter Car", "No vehicle found — spawn your car first.", 4) return end
    local driverSeat = vehicle:FindFirstChild("DriverSeat")
    if not driverSeat then Notify("Enter Car", "Driver seat not found!", 3) return end
    driverSeat:Sit(humanoid)
    Notify("Enter Car", "Success!", 2)
end

local function bringCar()
    local character = LocalPlayer.Character
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not hrp then Notify("Bring Car", "No character found!", 3) return end
    if issitting(humanoid) then Notify("Bring Car", "You're already in a vehicle!", 3) return end
    local vehicle = Functions:GetCurrentLocalPlayerCar() or GetVehicle()
    if not vehicle then Notify("Bring Car", "No vehicle found. Spawn your car first.", 4) return end
    local driverSeat = vehicle:FindFirstChild("DriverSeat")
    if not driverSeat then Notify("Bring Car", "Driver seat not found!", 3) return end

    local savedPosition = hrp.Position + Vector3.new(0, 3, 0)
    local camLook = Camera.CFrame.LookVector
    local flatLook = Vector3.new(camLook.X, 0, camLook.Z).Unit
    local targetCFrame = CFrame.lookAt(savedPosition, savedPosition + flatLook)

    Notify("Bring Car", "Bringing...", 2)
    driverSeat:Sit(humanoid)
    task.wait(0.3)
    vehicle:PivotTo(targetCFrame)
    Notify("Bring Car", "Success!", 3)
end

local isFlipping = false
local function flipCar()
    if isFlipping then return end
    local vehicle = Functions:GetCurrentLocalPlayerCar() or GetVehicle()
    if not vehicle or not vehicle.PrimaryPart then
        Notify("Flip Car", "No vehicle found - spawn your car first.", 4)
        return
    end
    isFlipping = true
    local primaryPart = vehicle.PrimaryPart
    local currentCF = vehicle:GetPivot()
    local look = currentCF.LookVector
    local flatLook = Vector3.new(look.X, 0, look.Z)
    if flatLook.Magnitude < 0.01 then flatLook = Vector3.new(0, 0, 1) end
    flatLook = flatLook.Unit
    local targetCF = CFrame.lookAt(currentCF.Position, currentCF.Position + flatLook)

    local steps = 20
    local current = currentCF
    for i = 1, steps do
        local alpha = i / steps
        local eased = 1 - (1 - alpha) ^ 2
        local interpolated = current:Lerp(targetCF, eased)
        vehicle:PivotTo(interpolated)
        pcall(function() primaryPart.AssemblyAngularVelocity = Vector3.zero end)
        RunService.Heartbeat:Wait()
    end
    vehicle:PivotTo(targetCF)
    pcall(function()
        primaryPart.AssemblyAngularVelocity = Vector3.zero
        primaryPart.AssemblyLinearVelocity = Vector3.zero
    end)
    isFlipping = false
    Notify("Flip Car", "Success!", 2)
end

-- ====================== Auto Apply on Car Entry ======================
local function ApplyDefaultMods(vehicle)
    if not vehicle then return end
    local ok, Drive = GetDrive(vehicle)
    if not ok then return end

    if not VehicleDefaults[vehicle] then StoreDefaults(vehicle) end

    -- Auto FWD
    rawset(Drive, "Config", "FWD")
    -- Auto Sharper Steering
    rawset(Drive, "SteerRatio", 13)
    rawset(Drive, "Ackerman", 1.1)
    rawset(Drive, "SteerSpeed", 0.05)

    TryRestartVehicleUI()

    Notify("Auto Mods", "FWD + Sharper Steering applied to new car", 3, "check-circle")
end

-- Listen for when player sits in any vehicle seat
local seatedConnection
local function SetupAutoApply()
    if seatedConnection then seatedConnection:Disconnect() end

    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")

    seatedConnection = humanoid.Seated:Connect(function(isSeated, seatPart)
        if isSeated and seatPart and seatPart.Name == "DriverSeat" then
            local vehicle = seatPart.Parent
            if vehicle and vehicle:IsDescendantOf(Vehicles) then
                task.wait(0.5) -- small delay to let Drive Controller load
                ApplyDefaultMods(vehicle)
            end
        end
    end)
end

