local function FetchWEAO(name)
    local ok, response = pcall(function()
        return request({
            Url = "https://weao.xyz/api/status/exploits/" .. name,
            Method = "GET",
            Headers = { ["User-Agent"] = "WEAO-3PService" },
        })
    end)
